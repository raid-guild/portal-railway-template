# Database connection string
DATABASE_URI=postgres://postgres:postgres@localhost:5432/<your-db-name>

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional shared secret for machine account self-registration at /api/agent/register.
# Leave unset to disable agent self-registration.
AGENT_REGISTRATION_SECRET=

# Optional SendGrid SMTP email delivery for password resets and other Payload emails.
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME="Community Portal"
SENDGRID_API_KEY=
